# Copy to .env and fill values. Each app also has its own .env.example.

# --- API ---
PORT=4000

# Local MongoDB
# MONGO_URI=mongodb://localhost:27017/melli_exchange

# MongoDB Atlas (replace with your own connection string from Atlas dashboard)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

COOKIE_DOMAIN=localhost
NODE_ENV=development

# --- Admin seed (used once by `pnpm seed`) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin

# --- Admin / Web ---
NEXT_PUBLIC_API_URL=http://localhost:4000
